{
	"version": 1,
	"base_image": "codeocean/jupyterlab:3.4.4-miniconda4.12.0-python3.9-ubuntu20.04",
	"post_install": true,
	"options": {
		"registry_host_arg": true,
		"git_ask_pass": true,
		"mount_secrets": true
	},
	"installers": {
		"apt": {
			"packages": [
				{
					"name": "vim",
					"version": "2:8.1.2269-1ubuntu5.32"
				}
			],
			"install_software_properties_common": true
		},
		"pip": {
			"packages": [
				{
					"name": "codeocean",
					"version": "0.15.0"
				},
				{
					"name": "h5py",
					"version": "3.14.0"
				},
				{
					"name": "matplotlib",
					"version": "3.9.4"
				},
				{
					"name": "numpy",
					"version": "2.0.2"
				},
				{
					"name": "opencv-python-headless",
					"version": "4.13.0.92"
				},
				{
					"name": "pandas",
					"version": "2.3.3"
				},
				{
					"name": "scanimage-tiff-reader",
					"version": "1.4.1.4"
				},
				{
					"name": "scipy",
					"version": "1.13.1"
				},
				{
					"name": "tifffile",
					"version": "2024.8.30"
				}
			],
			"options": {},
			"pre_install_options": {}
		}
