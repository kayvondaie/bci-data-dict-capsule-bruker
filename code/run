#!/usr/bin/env bash
set -ex

# Entry point for Reproducible Runs of this capsule.
#
# Reads SUBJECT, DATE, TARGET_STEM from environment variables (typically
# set by the bci_analysis orchestrator capsule's run_capsule API call).
# Produces /results/data_dict.pkl + /results/figures/*.png.
#
# To launch interactively from a workstation:
#   SUBJECT=850378 DATE=2026-05-26 TARGET_STEM=bci bash /code/run

cd /code
python -u run_session.py
